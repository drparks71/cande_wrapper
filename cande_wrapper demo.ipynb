    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"# Getting Started with cande-wrapper\\n\\nThis notebook demonstrates how to use the `cande-wrapper` Python package to run CANDE\\n(Culvert ANalysis and DEsign) finite element analyses.\\n\\n**Prerequisites:** The package must be installed with the compiled Fortran extension.\\nSee `README.md` for installation instructions.\\n\\n```bash\\npip install -e \\\".[dev]\\\"\\n```\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Import the package\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.373350Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.038911Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from cande_wrapper import CandeEngine\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import tempfile\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Set up a working directory\\n\",\n",
    "    \"\\n\",\n",
    "    \"CANDE reads input from `.cid` files and writes output files to the same directory.\\n\",\n",
    "    \"We'll copy the included example input file into a temporary working directory.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.385815700Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.375349500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Create a temporary working directory\\n\",\n",
    "    \"work_dir = Path(tempfile.mkdtemp(prefix=\\\"cande_demo_\\\"))\\n\",\n",
    "    \"print(f\\\"Working directory: {work_dir}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copy the example input file\\n\",\n",
    "    \"example_cid = Path(\\\"tests/example_data/MGK-IO.cid\\\")\\n\",\n",
    "    \"shutil.copy2(example_cid, work_dir / \\\"MGK-IO.cid\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Input file: {work_dir / 'MGK-IO.cid'}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Working directory: C:\\\\Users\\\\dane\\\\AppData\\\\Local\\\\Temp\\\\cande_demo_v_gat6dl\\n\",\n",
    "      \"Input file: C:\\\\Users\\\\dane\\\\AppData\\\\Local\\\\Temp\\\\cande_demo_v_gat6dl\\\\MGK-IO.cid\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Create the engine and verify input\\n\",\n",
    "    \"\\n\",\n",
    "    \"The `CandeEngine` takes a working directory where `.cid` files live.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.400767500Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.386812500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"engine = CandeEngine(work_dir=work_dir)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Verify the input file exists\\n\",\n",
    "    \"print(f\\\"Input file exists: {engine.check_input('MGK-IO')}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Input file exists: True\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 3\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Inspect the input file\\n\",\n",
    "    \"\\n\",\n",
    "    \"CANDE `.cid` files are fixed-format text. Let's look at the first few lines.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.411798900Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.400767500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"cid_text = (work_dir / \\\"MGK-IO.cid\\\").read_text()\\n\",\n",
    "    \"for i, line in enumerate(cid_text.splitlines()[:15], 1):\\n\",\n",
    "    \"    print(f\\\"{i:3d}: {line}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"  1:                       A-1!!ANALYS   3 0  2 Bandwidth minimizer example, house on stilts                                   \\n\",\n",
    "      \"  2:                    A-2.L3!!BASIC         2\\n\",\n",
    "      \"  3:                 B-1.Basic!!    1    2      1000         0        10        10         0\\n\",\n",
    "      \"  4:                 B-2.Basic!!    0\\n\",\n",
    "      \"  5:                    A-2.L3!!BASIC         2\\n\",\n",
    "      \"  6:                 B-1.Basic!!    1    2      1000         0        10        10         0\\n\",\n",
    "      \"  7:                 B-2.Basic!!    0\\n\",\n",
    "      \"  8:                    C-1.L3!!PREP    Non optimum node numbers                                        \\n\",\n",
    "      \"  9:                    C-2.L3!!    1    4    0    3    1   11    8    5    1    0    3\\n\",\n",
    "      \" 10:                    C-3.L3!!    1    0         0         0                         \\n\",\n",
    "      \" 11:                    C-3.L3!!    2    0        10         0                         \\n\",\n",
    "      \" 12:                    C-3.L3!!    6    0         0       2.5                         \\n\",\n",
    "      \" 13:                    C-3.L3!!    7    0        10       2.5                         \\n\",\n",
    "      \" 14:                    C-3.L3!!    8    0         0         5                         \\n\",\n",
    "      \" 15:                    C-3.L3!!    5    0         5         5                         \\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"## 5. Run the analysis\\n\\nCall `engine.run()` with the file prefix (without `.cid` extension).\\nThis runs the CANDE Fortran engine and returns a `CandeResult` object.\\n\\n> **Note:** This cell requires the compiled Fortran extension.\\n> If you haven't built it yet, see `README.md`.\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.559593300Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.411798900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"result = engine.run(\\\"MGK-IO\\\")\\n\",\n",
    "    \"print(result)\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"CandeResult(prefix='MGK-IO', output=C:\\\\Users\\\\dane\\\\AppData\\\\Local\\\\Temp\\\\cande_demo_v_gat6dl\\\\MGK-IO.out)\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 5\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Inspect the results\\n\",\n",
    "    \"\\n\",\n",
    "    \"The `CandeResult` object provides paths to all output files.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.569870200Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.560595500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"print(f\\\"Output file: {result.output_file}\\\")\\n\",\n",
    "    \"print(f\\\"Log file:    {result.log_file}\\\")\\n\",\n",
    "    \"print(f\\\"TOC file:    {result.toc_file}\\\")\\n\",\n",
    "    \"print()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# List all files created in the working directory\\n\",\n",
    "    \"print(\\\"All files in working directory:\\\")\\n\",\n",
    "    \"for f in sorted(work_dir.iterdir()):\\n\",\n",
    "    \"    print(f\\\"  {f.name} ({f.stat().st_size:,} bytes)\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Output file: C:\\\\Users\\\\dane\\\\AppData\\\\Local\\\\Temp\\\\cande_demo_v_gat6dl\\\\MGK-IO.out\\n\",\n",
    "      \"Log file:    C:\\\\Users\\\\dane\\\\AppData\\\\Local\\\\Temp\\\\cande_demo_v_gat6dl\\\\MGK-IO.log\\n\",\n",
    "      \"TOC file:    C:\\\\Users\\\\dane\\\\AppData\\\\Local\\\\Temp\\\\cande_demo_v_gat6dl\\\\MGK-IO.ctc\\n\",\n",
    "      \"\\n\",\n",
    "      \"All files in working directory:\\n\",\n",
    "      \"  MGK-IO.cid (4,649 bytes)\\n\",\n",
    "      \"  MGK-IO.ctc (964 bytes)\\n\",\n",
    "      \"  MGK-IO.log (760 bytes)\\n\",\n",
    "      \"  MGK-IO.out (24,386 bytes)\\n\",\n",
    "      \"  MGK-IO_BeamResults.xml (9,471 bytes)\\n\",\n",
    "      \"  MGK-IO_MeshGeom.xml (7,123 bytes)\\n\",\n",
    "      \"  MGK-IO_MeshResults.xml (7,154 bytes)\\n\",\n",
    "      \"  MGK-IO_PLOT1.dat (1,968 bytes)\\n\",\n",
    "      \"  MGK-IO_PLOT2.dat (1,751 bytes)\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 6\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Read the output report\\n\",\n",
    "    \"\\n\",\n",
    "    \"The `.out` file contains the full CANDE analysis report.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.586402800Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.570870400Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"output = result.output_text\\n\",\n",
    "    \"lines = output.splitlines()\\n\",\n",
    "    \"print(f\\\"Total output lines: {len(lines)}\\\")\\n\",\n",
    "    \"print()\\n\",\n",
    "    \"print(\\\"=== First 50 lines ===\\\")\\n\",\n",
    "    \"for line in lines[:50]:\\n\",\n",
    "    \"    print(line)\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Total output lines: 812\\n\",\n",
    "      \"\\n\",\n",
    "      \"=== First 50 lines ===\\n\",\n",
    "      \">>    Input file: MGK-IO.cid\\n\",\n",
    "      \">>    Output file: MGK-IO.out\\n\",\n",
    "      \">> \\n\",\n",
    "      \">> \\n\",\n",
    "      \">>          *** WELCOME TO CANDE-2025 (Version April 2025) ***\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"           *** WELCOME TO CANDE-2025 (Version April 2025) ***\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \" MASTER CONTROL AND PIPE-TYPE DATA FOR PROBLEM #  1, (P#1)\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"          USER TITLE:  Bandwidth minimizer example, house on stilts               \\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"          EXECUTION MODE ..................   ANALYS  \\n\",\n",
    "      \"\\n\",\n",
    "      \"          SOLUTION LEVEL ..................  #3 USER\\n\",\n",
    "      \"\\n\",\n",
    "      \"          METHODOLOGY (LRFD OR SERVICE) ...  SERVICE\\n\",\n",
