    "      \">>Problem title:  Bandwidth minimizer example, house on stilts\\n\",\n",
    "      \">> \\n\",\n",
    "      \">> \\n\",\n",
    "      \">>          EXECUTION MODE ..................   ANALYS\\n\",\n",
    "      \">> \\n\",\n",
    "      \">>          SOLUTION LEVEL ..................  #3 USER\\n\",\n",
    "      \">> \\n\",\n",
    "      \">>          METHODOLOGY (LRFD OR SERVICE) ...  SERVICE\\n\",\n",
    "      \">> \\n\",\n",
    "      \">>          NUMBER OF PIPE-ELEMENT GROUPS ...     2\\n\",\n",
    "      \">> \\n\",\n",
    "      \">>          MAXIMUM ITERATIONS PER STEP .....     30\\n\",\n",
    "      \">> \\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\",\n",
    "      \"\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 7\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-03T02:42:31.597572500Z\",\n",
    "     \"start_time\": \"2026-04-03T02:42:31.589400100Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Check for normal completion\\n\",\n",
    "    \"if \\\"NORMAL EXIT FROM CANDE\\\" in output:\\n\",\n",
    "    \"    print(\\\"Analysis completed successfully.\\\")\\n\",\n",
    "    \"else:\\n\",\n",
